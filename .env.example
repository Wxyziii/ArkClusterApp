# Frontend -> backend connection. Copy to `.env` for local dev.
# These are PUBLIC (bundled into the client) — only point them at a private
# Tailscale/LAN backend, never a public host.

# Rust manager base URL (no trailing slash).
VITE_ARK_API_BASE=http://127.0.0.1:8787

# Bearer token for /api/* — must match the backend's api_token /
# ARK_MANAGER_API_TOKEN. Leave empty to run the UI on mock data only.
VITE_ARK_API_TOKEN=change-me-dev-token
